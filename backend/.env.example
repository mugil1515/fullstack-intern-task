# ==============================
# SERVER
# ==============================
PORT=5000
NODE_ENV=development

# ==============================
# DATABASE (MySQL)
# ==============================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=saas_template_store

# ==============================
# JWT
# ==============================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ==============================
# CORS
# ==============================
CLIENT_URL=http://localhost:3000

# ==============================
# RATE LIMITING
# ==============================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
